# ────────────────────────────────────────────────────────────────────────────
# Tantum Ergo — environment template
# Copy to `.env` (and `.env.local` for editor secrets) and fill in.
# ────────────────────────────────────────────────────────────────────────────

# Supabase Postgres — use the *connection pooler* URI from
# Supabase → Project Settings → Database → "Connection string" → URI (pooler).
# Append `?pgbouncer=true` for transaction-pooled writes from serverless.
DATABASE_URI=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Payload secret — used to sign JWTs and cookies. Rotate per environment.
# Generate: `openssl rand -base64 48`
PAYLOAD_SECRET=replace-me-with-a-48-byte-random-string

# Preview secret — used to authenticate live-preview iframe loads.
# Generate: `openssl rand -base64 32`
PREVIEW_SECRET=replace-me-with-32-byte-random-string

# Public-facing origin. Used for live preview, CORS/CSRF allowlists, OG tags.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Email (Gmail SMTP via Google Workspace) ────────────────────────────────
# 1. Sign in to the Google account: https://myaccount.google.com → Security
# 2. Ensure 2-Step Verification is on
# 3. App Passwords → create one labelled "Tantum Ergo" → paste the 16-char value
#    into SMTP_PASS below (no spaces).
# If any of SMTP_HOST / SMTP_USER / SMTP_PASS are missing, Payload falls back
# to console-logging emails (useful for offline dev).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=joash@tenxafrica.co.za
SMTP_PASS=replace-with-google-app-password
SMTP_FROM_ADDRESS=joash@tenxafrica.co.za
SMTP_FROM_NAME=Tantum Ergo

# ─── Supabase Storage (Reliquary backing store) ─────────────────────────────
# When all four S3_* vars below are set, uploads to the `media` collection
# are routed to Supabase Storage via its S3-compatible endpoint. When unset,
# media falls back to local disk at ./media/ (fine for local dev; not for
# production).
#
# To enable:
#   1. Supabase dashboard → Storage → create a bucket (default: `tantum-reliquary`)
#      and mark it public (or wire signed URLs later).
#   2. Supabase dashboard → Project Settings → Storage → "S3 Connection" →
#      "New access key". Copy the Access key ID + Secret.
#   3. Fill in S3_REGION (e.g. eu-west-1, matching your project region) and the
#      endpoint host (the project ref part of your project URL).
#
SUPABASE_STORAGE_BUCKET=tantum-reliquary
SUPABASE_S3_ENDPOINT=https://[PROJECT_REF].supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-west-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
